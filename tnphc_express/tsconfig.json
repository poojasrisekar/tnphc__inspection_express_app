{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2020",
    "module": "CommonJS",        // ✅ important
    "moduleResolution": "Node",  // ✅ important

    "esModuleInterop": true,     // ✅ allows import express
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}