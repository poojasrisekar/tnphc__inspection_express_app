generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id             String   @id @unique @default(uuid()) @db.VarChar(36)
  email          String   @unique @map("email") @db.VarChar(255)
  code           Int      @default(autoincrement()) @map("code")
  createdAt      DateTime @default(now()) @map("created_at")
  createdById    String?  @map("created_by") @db.VarChar(255)
  isActive       Boolean  @default(true) @map("is_active")
  passwordHashed String   @map("password_hashed") @db.VarChar(255)
  passwordTemp   String   @map("password_temp") @db.VarChar(255)
  roleId         String?  @map("role_id") @db.VarChar(36)
  updatedAt      DateTime @updatedAt @map("updated_at")
  updatedById    String?  @map("updated_by") @db.VarChar(255)
  userName       String   @unique @map("user_name") @db.VarChar(15)
  role           Roles?   @relation(fields: [roleId], references: [id])

  @@index([code])
}

model Roles {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        Int      @default(autoincrement()) @map("code")
  name        String   @map("name") @db.VarChar(255)
  description String   @map("description") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by") @db.VarChar(255)
  updatedById String?  @map("updated_by") @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")
  users       user[]

  @@index([code])
}

model District {
  id          String    @id @default(uuid()) @db.VarChar(36)
  code        Int       @unique @map("code")
  name        String    @map("name") @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdById String?   @map("created_by") @db.VarChar(255)
  updatedById String?   @map("updated_by") @db.VarChar(255)
  isActive    Boolean   @default(true) @map("is_active")
  projects    project[]

  @@index([code])
  @@map("districts")
}

model specialUnits {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        Int      @default(autoincrement()) @map("code")
  name        String   @map("name") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by") @db.VarChar(255)
  updatedById String?  @map("updated_by") @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")

  projects project[]

  @@index([code])
  @@map("special_units")
}

model LandSiteInspection {
  id        String @id @default(uuid())
  projectId String

  // 🔹 Encroachment
  isEncroachment        YesNo
  encroachmentPercent   Float?
  encroachmentType      String?
  isCourtCase           YesNo
  caseDetails           String?

  // 🔹 Existing Structure
  hasStructure          YesNo
  structureDetails      String?

  // 🔹 Drainage
  isLowLying            YesNo
  waterDepth            Float?
  waterDurationDays     Int?

  // 🔹 Trees
  treesCount            Int?
  treesPhoto            Json?

  // 🔹 Power Lines
  hasPowerLines         YesNo
  powerLineDetails      String?

  // 🔹 Restricted Zones
  isNearMonument        YesNo
  monumentName          String?
  monumentDistance      Float?

  isNearSea             YesNo
  seaDistance           Float?

  isNearForest          YesNo
  forestName            String?
  forestDistance        Float?

  isNearWaterBody       Boolean?
  waterBodyName         String?
  waterBodyDistance     Float?

  // 🔹 Burial Ground
  isNearBurial          YesNo
  burialName            String?
  burialDistance        Float?

  // 🔹 Roads
  roadType              String?
  roadWidth             Float?

  // 🔹 Essential Services
  nearestService        String?
  serviceDistance       Float?

  // 🔹 Common
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by") @db.VarChar(255)
  updatedById String?  @map("updated_by") @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")

  project project @relation(fields: [projectId], references: [id])
}

model project {
  id   String @id @default(uuid()) @db.VarChar(36)
  code Int    @default(autoincrement()) @map("code")

  // Common
  districtId String
  district   District @relation(fields: [districtId], references: [id])

  // Either Department OR Special Unit
  department    department? @relation(fields: [departmentId], references: [id])
  departmentId  String? // FK
  specialUnitId String? // FK

  specialUnit specialUnits? @relation(fields: [specialUnitId], references: [id])

  // Common
  officer     officer? @relation(fields: [officerId], references: [id])
  officerId    String? // FK
  locationName String
  projectName  String


  stages stage[]

  status status @default(AssignedProjects)  // ✅ default here



  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by") @db.VarChar(255)
  updatedById String?  @map("updated_by") @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")

  landSiteInspection LandSiteInspection[]
}

model officer{
  id   String @id @default(uuid()) @db.VarChar(36)
  code Int    @default(autoincrement()) @map("code")
  name String @map("name") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by") @db.VarChar(255)
  updatedById String?  @map("updated_by") @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")
  projects project[]
}


model department {
  id   String @id @default(uuid()) @db.VarChar(36)
  code Int    @default(autoincrement()) @map("code")
  name String @map("name") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by") @db.VarChar(255)
  updatedById String?  @map("updated_by") @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")
  projects project[]
}

model AuditLog {
  id   String @id @default(uuid()) @db.VarChar(36)
  code Int    @unique @default(autoincrement())

  tableName String @map("table_name") @db.VarChar(100)
  recordId  String @map("record_id") @db.VarChar(36)

  action String @db.VarChar(20) // CREATE | UPDATE | DELETE

  oldValue Json? @map("old_value")
  newValue Json? @map("new_value")

  userId    String? @map("user_id") @db.VarChar(36)
  roleId    String? @map("role_id") @db.VarChar(36)
  ipAddress String? @map("ip_address") @db.VarChar(45)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  createdById String?  @map("created_by_id") @db.VarChar(36)
  updatedById String?  @map("updated_by_id") @db.VarChar(36)
  isActive    Boolean  @default(true) @map("is_active")

  @@index([tableName])
  @@index([recordId])
  @@map("audit_logs")
}


model stage {
    id   String @id @default(uuid()) @db.VarChar(36)
    code Int    @default(autoincrement()) @map("code")
    name String @map("name") @db.VarChar(255)
    createdAt   DateTime @default(now()) @map("created_at")
    updatedAt   DateTime @updatedAt @map("updated_at")
    createdById String?  @map("created_by") @db.VarChar(255)
    updatedById String?  @map("updated_by") @db.VarChar(255)
    isActive    Boolean  @default(true) @map("is_active")
    projects project[]

}

model material {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        Int      @unique @default(autoincrement())
  name        String   @map("material_name") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")
  isActive    Boolean  @default(true) @map("is_active")

  brands      brand[]

  @@index([code])
}

model brand {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        Int      @unique @default(autoincrement())
  name        String   @map("brand_name") @db.VarChar(255)

  materialId  String
  material    material @relation(fields: [materialId], references: [id])

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")
  isActive    Boolean  @default(true) @map("is_active")

  grades      grade[]
  masters     Master[]

  @@index([code])
  @@index([materialId])

}

model grade {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        Int      @default(autoincrement())
  name        String   @map("grade_name") @db.VarChar(255)

  brandId     String
  brand       brand @relation(fields: [brandId], references: [id])

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")
  isActive    Boolean  @default(true) @map("is_active")
  masters     Master[]

  @@index([code])
  @@index([brandId])
}

enum status {
  TotalProjects
  CompletedProjects
  OngoingProjects
  AssignedProjects
}

enum YesNo {
  Yes
  No
}



model Master {
  id            String   @id @default(uuid()) @db.VarChar(36)
  code          Int      @unique @default(autoincrement())

  brandId       String
  gradeId       String

  materialName  String   @map("material_name") @db.VarChar(255)

  brand         brand    @relation(fields: [brandId], references: [id])
  grade         grade    @relation(fields: [gradeId], references: [id])

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdById   String?  @map("created_by")
  updatedById   String?  @map("updated_by")
  isActive      Boolean  @default(true) @map("is_active")

  @@index([brandId])
  @@index([gradeId])
}
