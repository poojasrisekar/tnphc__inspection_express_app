generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id             String   @id @unique @default(uuid()) @db.VarChar(36)
  email          String   @unique @map("email") @db.VarChar(255)
  code           Int      @default(autoincrement()) @map("code")
  createdAt      DateTime @default(now()) @map("created_at")
  createdById    String?  @map("created_by") @db.VarChar(255)
  isActive       Boolean  @default(true) @map("is_active")
  passwordHashed String   @map("password_hashed") @db.VarChar(255)
  passwordTemp   String   @map("password_temp") @db.VarChar(255)
  roleId         String?  @map("role_id") @db.VarChar(36)
  departmentId   String?  @map("department_id") @db.VarChar(36) 
  specialUnitId  String?  @map("special_unit_id") @db.VarChar(36) 
  districtId     String?  @map("district_id") @db.VarChar(36)
  officerId      String?  @map("officer_id") @db.VarChar(36)
  updatedAt      DateTime @updatedAt @map("updated_at")
  updatedById    String?  @map("updated_by") @db.VarChar(255)
  userName       String   @unique @map("user_name") @db.VarChar(15)

  role       Roles?      @relation(fields: [roleId], references: [id])
  department department? @relation(fields: [departmentId], references: [id]) // ← ADD
  district   District?   @relation(fields: [districtId], references: [id])
  officer    officer?    @relation(fields: [officerId], references: [id])
    specialUnit    specialUnits? @relation(fields: [specialUnitId], references: [id])  // ← ADD
    assignedProjects project[]
 
   
  @@index([specialUnitId, districtId, userName])

  @@index([code])
  @@index([departmentId, districtId, userName])
}

model Roles {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        Int      @default(autoincrement()) @map("code")
  name        String   @map("name") @db.VarChar(255)
  description String   @map("description") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by") @db.VarChar(255)
  updatedById String?  @map("updated_by") @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")
  users       user[]

  @@index([code])
}

model District {
  id          String    @id @default(uuid()) @db.VarChar(36)
  code        Int       @unique @map("code")
  name        String    @map("name") @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdById String?   @map("created_by") @db.VarChar(255)
  updatedById String?   @map("updated_by") @db.VarChar(255)
  isActive    Boolean   @default(true) @map("is_active")
  projects    project[]
  users       user[]

  @@index([code])
  @@map("districts")
}

model specialUnits {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        Int      @default(autoincrement()) @map("code")
  name        String   @map("name") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by") @db.VarChar(255)
  updatedById String?  @map("updated_by") @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")

  users    user[]
  projects project[]


  @@index([code])
  @@map("special_units")
}

model LandSiteInspection {
  id        String @id @default(uuid())
  projectId String

  // 🔹 Encroachment
  isEncroachment      YesNo
  encroachmentPercent Float?
  encroachmentType    String?
  personEncroachingName String?
  encroachmentPhotos  Json? 

  isCourtCase         YesNo
  caseDetails         String?

  // 🔹 Existing Structure
  hasStructure     YesNo
  structureDetails String?
  structurePhotos  Json?

  // 🔹 Drainage
  isLowLying        YesNo
  waterDepth        Float?
  waterDurationDays Int?
  drainagePhotos    Json?

  // 🔹 Trees
  treesCount Int?
  treesPhoto Json?

  // 🔹 Power Lines
  hasPowerLines    YesNo
  powerLineDetails String?
  powerLinePhotos  Json?

  // 🔹 Restricted Zones
  isNearMonument   YesNo
  monumentName     String?
  monumentDistance Float?
  monumentPhotos   Json?

  isNearSea   YesNo
  seaDistance Float?
  seaPhotos   Json?

  isNearForest   YesNo
  forestName     String?
  forestDistance Float?
  forestPhotos   Json?

  isNearWaterBody   Boolean?
  waterBodyName     String?
  waterBodyDistance Float?
  waterBodyPhotos   Json?

  // 🔹 Burial Ground
  isNearBurial   YesNo
  burialName     String?
  burialDistance Float?
  burialPhotos   Json?

  // 🔹 Roads
  roadType  String?
  roadWidth Float?

  // 🔹 Essential Services
  nearestService  String?
  serviceDistance Float?

  // 🔹 Common
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by") @db.VarChar(255)
  updatedById String?  @map("updated_by") @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")

  project project @relation(fields: [projectId], references: [id])
}

model project {
  id   String @id @default(uuid()) @db.VarChar(36)
  code Int    @default(autoincrement()) @map("code")

  // Common
  districtId String
  district   District @relation(fields: [districtId], references: [id])

  // Either Department OR Special Unit
  department    department? @relation(fields: [departmentId], references: [id])
  departmentId  String? // FK
  specialUnitId String? // FK

  specialUnit specialUnits? @relation(fields: [specialUnitId], references: [id])

  // Common
  officer      officer? @relation(fields: [officerId], references: [id])
  officerId    String? // FK
  locationName String
  projectName  String
    // ✅ NEW: store selected stage ids
  selectedStageIds Json? @map("selected_stage_ids")

  // ✅ NEW: assign user
  assignedUserId String? @db.VarChar(36)
  assignedUser   user?   @relation(fields: [assignedUserId], references: [id])

  stages stage[]

  status status @default(AssignedProjects) //  default here

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by") @db.VarChar(255)
  updatedById String?  @map("updated_by") @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")

  landSiteInspection         LandSiteInspection[]
  preConstructionInspections PreConstructionInspection[]
  foundationProgresses       FoundationProgress[]
  foundationQualityChecks    FoundationQualityCheck[]
  plinthStages               PlinthStage[]
  interiorsProgress interiorsProgress[]
interiorsQuality interiorsQuality?
  exteriorsProgress exteriorsProgress[]
exteriorsQuality exteriorsQuality?
  BuildingInspection         BuildingInspection[]
  DevelopmentWork            DevelopmentWork[]
  TakeoverBuildingInsepction TakeoverBuildingInspection[]
  TakeoverDevelopmentWork    TakeoverDevelopmentWork[]

  SuperStructure         superStructure[]
    SuperStructureProgress superStructureProgress[]

  
  superStructureQuality  superStructureQuality?
}

model officer {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        Int      @default(autoincrement()) @map("code")
  name        String   @map("name") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by") @db.VarChar(255)
  updatedById String?  @map("updated_by") @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")

  users    user[]
  projects project[]
}

model department {
  id          String    @id @default(uuid()) @db.VarChar(36)
  code        Int       @default(autoincrement()) @map("code")
  name        String    @map("name") @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdById String?   @map("created_by") @db.VarChar(255)
  updatedById String?   @map("updated_by") @db.VarChar(255)
  isActive    Boolean   @default(true) @map("is_active")
  projects    project[]
  users       user[]

  @@map("department")
}

model AuditLog {
  id   String @id @default(uuid()) @db.VarChar(36)
  code Int    @unique @default(autoincrement())

  tableName String @map("table_name") @db.VarChar(100)
  recordId  String @map("record_id") @db.VarChar(36)

  action String @db.VarChar(20) // CREATE | UPDATE | DELETE

  oldValue Json? @map("old_value")
  newValue Json? @map("new_value")

  userId    String? @map("user_id") @db.VarChar(36)
  roleId    String? @map("role_id") @db.VarChar(36)
  ipAddress String? @map("ip_address") @db.VarChar(45)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  createdById String?  @map("created_by_id") @db.VarChar(36)
  updatedById String?  @map("updated_by_id") @db.VarChar(36)
  isActive    Boolean  @default(true) @map("is_active")

  @@index([tableName])
  @@index([recordId])
  @@map("audit_logs")
}

model stage {
  id          String    @id @default(uuid()) @db.VarChar(36)
  code        Int       @default(autoincrement()) @map("code")
  name        String    @map("name") @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdById String?   @map("created_by") @db.VarChar(255)
  updatedById String?   @map("updated_by") @db.VarChar(255)
  isActive    Boolean   @default(true) @map("is_active")
  projects    project[]
}

model material {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        Int      @unique @default(autoincrement())

  name        String   @unique @map("material_name") @db.VarChar(255)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")

  isActive    Boolean  @default(true) @map("is_active")

  brands      brand[]

  @@index([code])
}

model brand {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        Int      @unique @default(autoincrement())

  name        String   @map("brand_name") @db.VarChar(255)

  materialId  String
  material    material @relation(fields: [materialId], references: [id])

  grades      grade[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")

  isActive    Boolean  @default(true) @map("is_active")

  @@unique([materialId, name])

  @@index([code])
  @@index([materialId])
}

model grade {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        Int      @unique @default(autoincrement())

  name        String   @map("grade_name") @db.VarChar(255)

  brandId     String
  brand       brand    @relation(fields: [brandId], references: [id])

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")

  isActive    Boolean  @default(true) @map("is_active")

  @@unique([brandId, name])

  @@index([code])
  @@index([brandId])
}

enum status {
  TotalProjects
  CompletedProjects
  OngoingProjects
  AssignedProjects
}

enum YesNo {
  Yes
  No
}



model PreConstructionInspection {
  id        String @id @default(uuid())
  projectId String

  //  Permissions
  isPermissionObtained YesNo
  permissionDate       DateTime?

  //  Site Clearance
  isSiteCleared YesNo
  siteDetails   String?

  //  Labour Shed
  hasLabourShed  YesNo
  labourShedType String?
  labourShedArea Float?

  hasWaterSupply    YesNo
  waterSupplyPhotos Json?

  hasToiletFacility YesNo
  toiletPhotos      Json?

  hasElectricity    YesNo
  electricityPhotos Json?

  //  Labour Registration
  labourCount  Int?
  labourPhotos Json?

  //  Material Storage
  hasMaterialStorage YesNo
  materialType       String?
  materialPhotos     Json?

  //  Electricity & Water
  hasTempElectricity YesNo
  waterType          String?

  // Access Road
  isAccessRoadGood YesNo
  accessRoadPhotos Json?

  //  Remarks
  remarks String?

  //  Common
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  isActive    Boolean  @default(true)

  project project @relation(fields: [projectId], references: [id])
}

model FoundationProgress {
  id        String @id @default(uuid())
  projectId String

  type FoundationType // Footing | Pile | Raft

  // COMMON
  total     Int?
  completed Int?
  photos    Json?

  workStartedDate DateTime?

  isDelay     Boolean @default(false)
  delayDays   Int?
  delayPhotos Json?

  delayReason      String?
  delayOtherReason String?

  generalRemarks String?

  // ONLY FOR RAFT
  raftType String?

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String?  @map("created_by")
  updatedById String?  @map("updated_by")
  isActive    Boolean  @default(true) @map("is_active")

  project project @relation(fields: [projectId], references: [id])
}

enum FoundationType {
  Footing
  Pile
  Raft
}

